# ============================================================================
# Configurazione backend — copia questo file in "backend/.env" e modificalo.
# ============================================================================

PORT=8080

# ---- Database PostgreSQL locale ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/regexriddle

# ---- PostgreSQL cloud ----
# Neon:     DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/regexriddle?sslmode=require
# Supabase: DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# ---- JWT ----
JWT_SECRET=chiaveSuperSegretaLungaAlmenoTrentadueCarat
JWT_EXPIRATION=86400000
