generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int         @id @default(autoincrement())
  username     String      @unique
  email        String      @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime    @default(now())
  challenges   Challenge[]
  attempts     Attempt[]

  @@map("users")
}

model Challenge {
  id                     Int       @id @default(autoincrement())
  author                 User      @relation(fields: [authorId], references: [id])
  authorId               Int
  title                  String
  description            String?
  exampleMatch           String
  exampleNoMatch         String
  // Segreti: mai esposti dalle API
  secretRegex            String
  controlStringsPositive Json
  controlStringsNegative Json
  createdAt              DateTime  @default(now())
  attempts               Attempt[]

  @@index([authorId])
  @@map("challenges")
}

model Attempt {
  id              Int       @id @default(autoincrement())
  user            User      @relation(fields: [userId], references: [id])
  userId          Int
  challenge       Challenge @relation(fields: [challengeId], references: [id])
  challengeId     Int
  proposedRegex   String
  positiveMatched Int
  negativeMatched Int
  totalPositive   Int
  totalNegative   Int
  solved          Boolean
  attemptedAt     DateTime  @default(now())

  // Indici a supporto delle aggregazioni (conteggi per sfida, statistiche e
  // classifica per utente, lookup delle sfide risolte).
  @@index([challengeId])
  @@index([userId])
  @@index([userId, solved])
  @@map("attempts")
}
